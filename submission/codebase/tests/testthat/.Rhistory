dgp <- generate_ar_dgp(m = 2, variance = 2, n = 50, seed = 1)
dgp1 <- generate_ar_dgp(m = 2, variance = 2, n = 50, seed = 1, ar_mean = 5)
m1 <- mean(as.numeric(dgp$x))
m2 <- mean(as.numeric(dgp1$x))
expect_true(m2 > m1 + 4)
})
